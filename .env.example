# ==============================================================================
# 1. GENERAL & COMPOSE CONFIG
# ==============================================================================
COMPOSE_PROJECT_NAME=opendx-lab
DOMAIN=localhost

# ==============================================================================
# 2. POSTGRESQL CONFIG (Shared Relational Database)
# ==============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=opendx_admin
POSTGRES_PASSWORD=secure_postgres_pass_123

# Individual DB names for services (created automatically on startup if configured)
POSTGRES_DB_KEYCLOAK=keycloak_db
POSTGRES_DB_WIKIJS=wikijs_db
POSTGRES_DB_N8N=n8n_db
POSTGRES_DB_METABASE=metabase_db
POSTGRES_DB_DASHBOARD=dashboard_db
POSTGRES_DB_MATTERMOST=mattermost_db

# ==============================================================================
# 3. MATTERMOST CONFIG (Internal Team Communication)
# ==============================================================================
MATTERMOST_PORT=3100
MM_SQLSETTINGS_DRIVERNAME=postgres
MM_SQLSETTINGS_DATASOURCE=postgres://opendx_admin:secure_postgres_pass_123@postgres:5432/mattermost_db?sslmode=disable&connect_timeout=10
MM_SERVICESETTINGS_SITEURL=http://localhost:3100

# ==============================================================================
# 4. KEYCLOAK CONFIG (SSO / IAM)
# ==============================================================================
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak_db
KC_DB_USERNAME=opendx_admin
KC_DB_PASSWORD=secure_postgres_pass_123

# ==============================================================================
# 5. WIKI.JS CONFIG
# ==============================================================================
WIKIJS_PORT=3200
WIKIJS_DB_TYPE=postgres
WIKIJS_DB_HOST=postgres
WIKIJS_DB_PORT=5432
WIKIJS_DB_USER=opendx_admin
WIKIJS_DB_PASS=secure_postgres_pass_123
WIKIJS_DB_NAME=wikijs_db

# ==============================================================================
# 6. N8N WORKFLOW AUTOMATION CONFIG
# ==============================================================================
N8N_PORT=5678
N8N_ENCRYPTION_KEY=n8n_secure_encryption_key_xyz_123
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n_db
N8N_DB_POSTGRESDB_USER=opendx_admin
N8N_DB_POSTGRESDB_PASSWORD=secure_postgres_pass_123

# ==============================================================================
# 7. METABASE BI CONFIG
# ==============================================================================
METABASE_PORT=3300
MB_DB_TYPE=postgres
MB_DB_HOST=postgres
MB_DB_PORT=5432
MB_DB_DBNAME=metabase_db
MB_DB_USER=opendx_admin
MB_DB_PASS=secure_postgres_pass_123

# ==============================================================================
# 8. OLLAMA CONFIG (Local AI / LLM)
# ==============================================================================
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0
# Model to be pulled by default (e.g. qwen2.5:7b, qwen2.5:3b, llama3.2, etc.)
OLLAMA_DEFAULT_MODEL=qwen2.5:3b

# ==============================================================================
# 9. NEXT.JS DASHBOARD CONFIG (Core Custom Application)
# ==============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://opendx_admin:secure_postgres_pass_123@postgres:5432/dashboard_db

# SSO Authentication (NextAuth with Keycloak Provider)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=nextauth_secret_session_encryption_key_456
KEYCLOAK_CLIENT_ID=opendx-dashboard
KEYCLOAK_CLIENT_SECRET=keycloak_client_secret_to_be_generated
KEYCLOAK_ISSUER=http://localhost:8080/realms/opendx

# Internal APIs for Dashboard Communication
OLLAMA_API_URL=http://ollama:11434
METABASE_SITE_URL=http://localhost:3300
METABASE_SECRET_KEY=metabase_dashboard_embed_secret_key_789
